# ─── Identify Top 6 Characters by Dialogue Volume ────────────────────────────
top_characters <- hamlet %>%
filter(character != "[stage direction]") %>%
count(character, sort = TRUE) %>%
slice_max(n, n = 6)
main_characters <- top_characters$character
main_characters
